{
  "name": "ultra-logger",
  "version": "1.0.0",
  "description": "A advanced logger",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "url": "git+https://github.com/constttdev/ultra-logger.git",
    "type": "git",
    "clean:win": "rmdir /s dist",
    "clean:linux": "rm -rf dist",
    "clean:macos": "rm -rf dist"
  },
  "scripts": {
    "start": "npx tsx src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts"
  },
  "keywords": [
    "logging",
    "ultra-logger",
    "advanced",
    "advanced-loggin",
    "logger"
  ],
  "author": "constt",
  "license": "GNU-GPLv3",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
